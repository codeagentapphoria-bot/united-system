# proc-compose auto-injects this at runtime for local dev.
# DEPLOYMENT: set VITE_API_BASE_URL in Railway dashboard as:
#   https://${{RAILWAY_PUBLIC_DOMAIN}}/api
# Must be HTTPS — the app throws an error on non-localhost HTTP in production.
VITE_API_BASE_URL=http://localhost:3000/api

VITE_PORTAL_URL=http://localhost:3000

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_TIMEOUT=120000
