# Redis — used for session state (Phase B), Bull audit queue, and general cache.
# Code falls back to localhost:6379 if unset, and degrades gracefully if Redis
# is unreachable (sessions become advisory, audit writes go inline).
REDIS_URL=redis://localhost:6379

DEBUG_DB=false

# OpenTelemetry APM — leave blank to disable (no SDK overhead).
# Set to an OTLP/HTTP endpoint to export traces (e.g. Grafana Tempo, Honeycomb, Datadog OTel).
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com
# OTEL_SERVICE_NAME=multysis-backend
# OTEL_SERVICE_VERSION=2.0.0
