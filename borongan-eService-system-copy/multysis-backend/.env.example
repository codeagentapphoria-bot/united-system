# DEPLOYMENT: set both to your production database connection strings.
# Append `?connection_limit=25&pool_timeout=20` to DATABASE_URL in prod — this caps the
# Prisma pool at 25 sockets (matches a single-server Node process sized for ~80k users)
# and gives requests 20s to acquire a connection before failing fast. Raise connection_limit
# proportionally if the DB box gains CPU/RAM; drop it if Postgres max_connections is tight.
# DIRECT_URL must stay pool-less (used by `prisma migrate`).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/united_systems?connection_limit=25&pool_timeout=20
DIRECT_URL=postgres://postgres:postgres@localhost:5432/united_systems

# DEPLOYMENT: must be identical to BIMS server JWT_SECRET
JWT_SECRET=91e37e5f13dcd8bb141ada5ba5b34bd1e5cd71e39f60119fe1795914008ccadbcd8fd74e447a44355ceffa161497244a

PORT=8081
NODE_ENV=production
# DEPLOYMENT: set to this service's Railway public URL (e.g. https://eservice.up.railway.app)
API_BASE_URL=http://localhost:8081

ACCESS_TOKEN_EXPIRES=10m
REFRESH_TOKEN_EXPIRES=30d
IDLE_TIMEOUT=15m
ABSOLUTE_TIMEOUT=6h

COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
COOKIE_PATH=/

# DEPLOYMENT: set to the BIMS service's Railway public URL (e.g. https://bims.up.railway.app)
CORS_ORIGIN=http://localhost:8080
# DEPLOYMENT: set to this service's Railway public URL
PORTAL_URL=http://localhost:8081

